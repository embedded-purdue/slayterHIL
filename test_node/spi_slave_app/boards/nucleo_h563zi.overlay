//SPI slave on the Nucleo H563ZI's SPI1 controller.
//SPI1 pins (from board DTS):
//SCK = PA5
//MOSI = PB5
//MISO = PG9
//CS = PD14

&spi1 {
    spi_dev: spi_dev@0 {
        compatible = "vnd,spi-device";
        reg = <0>;
        spi-max-frequency = <1000000>;
        label = "spi_dev";
    };
};
