/ {
    aliases {
        i2c-lidar = &i2c1;
        i2c-imu = &i2c2;
        uart-rc = &uart4;
        pwm-input = &timers3_pwm;
        spi-fs = &spi1;
    };
};

&spi1 {
    spi_dev: spi_dev@0 {
        compatible = "vnd,spi-device";
        reg = <0>;
        spi-max-frequency = <1000000>;
        label = "spi_dev";
    };
};

&i2c1 {
    status = "okay";
    pinctrl-0 = <&i2c1_scl_pb8 &i2c1_sda_pb9>;
    pinctrl-names = "default";
};

&i2c2 {
    status = "okay";
    pinctrl-0 = <&i2c2_scl_pf1 &i2c2_sda_pf0>;
    pinctrl-names = "default";
};

&uart4 {
    status = "okay";
    pinctrl-0 = <&uart4_tx_pa0 &uart4_rx_pd11>;
    pinctrl-names = "default";
};

&timers3 {
    status = "okay";
    st,prescaler = <10000>; // may need to change later

    timers3_pwm: pwm {
        status = "okay";
        pinctrl-0 = <&tim3_ch1_pb4>;
        pinctrl-names = "default";
    };
};
