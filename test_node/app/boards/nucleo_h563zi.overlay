/ {
    aliases {
        i2c-lidar = &i2c1;
        i2c-imu = &i2c2;

        pwm-input1 = &timers1_pwm;
        pwm-input2 = &timers2_pwm;
        pwm-input3 = &timers3_pwm;
        pwm-input4 = &timers4_pwm;
        uart-rc = &uart4;
    };
};

&spi4 {
    status = "okay";
    pinctrl-0 = <&spi4_sck_pe2
                 &spi4_nss_pe4
                 &spi4_miso_pe5
                 &spi4_mosi_pe6>;
    pinctrl-names = "default";
};

&i2c2 {
    status = "okay";
    pinctrl-0 = <&i2c2_scl_pf1 &i2c2_sda_pf0>;
    pinctrl-names = "default";
    clock-frequency = <I2C_BITRATE_FAST>;
};

&i2c4 {
    status = "okay";
    pinctrl-0 = <&i2c4_scl_pd12 &i2c4_sda_pd13>;
    pinctrl-names = "default";
    clock-frequency = <I2C_BITRATE_FAST>;
};

&timers1 {
    status = "okay";
    st,prescaler = <250>; // may need to change later

    timers1_pwm: pwm {
        status = "okay";
        pinctrl-0 = <&tim1_ch1_pa8>;
        pinctrl-names = "default";
    };
};

&timers2 {
    status = "okay";
    st,prescaler = <250>; // may need to change later

    timers2_pwm: pwm {
        status = "okay";
        pinctrl-0 = <&tim2_ch1_pa0>;
        pinctrl-names = "default";
    };
};
&uart4 {
    status = "okay";
    pinctrl-0 = <&uart4_tx_pa0 &uart4_rx_pd11>;
    pinctrl-names = "default";
};

&timers3 {
    status = "okay";
    st,prescaler = <250>; // may need to change later

    timers3_pwm: pwm {
        status = "okay";
        pinctrl-0 = <&tim3_ch1_pb4>;
        pinctrl-names = "default";
    };
};

&timers4 {
    status = "okay";
    st,prescaler = <250>; // may need to change later

    timers4_pwm: pwm {
        status = "okay";
        pinctrl-0 = <&tim4_ch1_pd12>;
        pinctrl-names = "default";
    };
};
