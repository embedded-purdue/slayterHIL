# ------------------
#  Configurables
# ------------------
SIM_BOARD        := "qemu_x86"

STM32_BOARD      := "nucleo_h563zi"
STM32_PORT       := "/dev/ttyACM0" #ST-LINK virtual COM port; adjust if needed

#ESP32 (keeping for reference)
ESP_BOARD      := "esp32s3_devkitc/esp32s3/procpu"
ESP_PORT       := "/dev/ttyUSB0"

CMAKE_CACHE_ARGS := "-- -DCMAKE_EXPORT_COMPILE_COMMANDS=ON"

# set shell := ["bash", "-eu", "-o", "pipefail", "-c"]

# ------------------
#  Helpers
# ------------------
_verify_workspace:
  test -d .west || { echo "ERROR: .west not found here. Ensure in firmware/ and README installation instructions have been followed."; exit 1; }

# ------------------
#  Sim (QEMU)
# ------------------

build-sim: _verify_workspace clean
  west build \
    -p always \
    -b {{SIM_BOARD}} \
    -d build \
    app \
    {{CMAKE_CACHE_ARGS}}

run-sim: build-sim
  west build -t run -d build

# ------------------
#  STM32 Nucleo
# ------------------

build-stm32: _verify_workspace clean
  west build \
    -p always \
    -b {{STM32_BOARD}} \
    -d build \
    app \
    {{CMAKE_CACHE_ARGS}}

build-stm32-spi-example: _verify_workspace clean
  west build \
    -p always \
    -b {{STM32_BOARD}} \
    -d build \
    spi_example_app \
    {{CMAKE_CACHE_ARGS}}

build-stm32-spi-bitbang: _verify_workspace clean
  west build \
    -p always \
    -b {{STM32_BOARD}} \
    -d build \
    spi_bitbang_app \
    {{CMAKE_CACHE_ARGS}}

build-stm32-spi-slave: _verify_workspace clean
  west build \
    -p always \
    -b {{STM32_BOARD}} \
    -d build \
    spi_slave_app \
    {{CMAKE_CACHE_ARGS}}

flash-stm32:
  west flash --build-dir build --runner stm32cubeprogrammer

flash-stm32-pyocd:
  west flash --build-dir build --runner pyocd

monitor-stm32:
  python -m serial.tools.miniterm "{{STM32_PORT}}" 115200

run-stm32: build-stm32 flash-stm32 monitor-stm32

run-stm32-pyocd: build-stm32 flash-stm32-pyocd monitor-stm32

run-stm32-spi-example: build-stm32-spi-example flash-stm32 monitor-stm32

run-stm32-spi-example-pyocd: build-stm32-spi-example flash-stm32-pyocd monitor-stm32

run-stm32-spi-bitbang: build-stm32-spi-bitbang flash-stm32 monitor-stm32

run-stm32-spi-bitbang-pyocd: build-stm32-spi-bitbang flash-stm32-pyocd monitor-stm32

run-stm32-spi-slave: build-stm32-spi-slave flash-stm32 monitor-stm32

run-stm32-spi-slave-pyocd: build-stm32-spi-slave flash-stm32-pyocd monitor-stm32

attach-wsl-usb-port:
  #!/usr/bin/env bash
  set -euo pipefail

  BUSID=$(usbipd.exe list | grep "ST-Link" | awk 'NR==1 {print $1}')

  if [ -z "$BUSID" ]; then
    echo "Device not found: ST-Link"
    echo "Make sure the Nucleo board is plugged in via USB."
    exit 1
  fi

  echo "Found device on BUSID: $BUSID"

  usbipd.exe bind --busid "$BUSID"
  usbipd.exe attach --wsl --busid "$BUSID"

  echo "Device attached to WSL."

